# Diversity-First RAG — Environment Configuration
# Copy to .env and fill in your values.
# Never commit .env to version control.

# Path to your ChromaDB persistent storage directory.
# Use an absolute path to avoid accidental data exposure.
# Default: ./chroma_db  (relative to experiments/)
CHROMA_PATH=/path/to/your/chroma_db

# ChromaDB collection name that holds your document embeddings.
# Default: my_collection
CHROMA_COLLECTION=my_collection
